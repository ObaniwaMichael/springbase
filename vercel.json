{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "functions": {
    "api/schedule-tour.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/students",
      "destination": "https://students.springbase.com.ng",
      "permanent": false
    },
    {
      "source": "/students/(.*)",
      "destination": "https://students.springbase.com.ng/$1",
      "permanent": false
    },
    {
      "source": "/parents",
      "destination": "https://parents.springbase.com.ng",
      "permanent": false
    },
    {
      "source": "/parents/(.*)",
      "destination": "https://parents.springbase.com.ng/$1",
      "permanent": false
    },
    {
      "source": "/admin",
      "destination": "https://admin.springbase.com.ng",
      "permanent": false
    },
    {
      "source": "/admin/(.*)",
      "destination": "https://admin.springbase.com.ng/$1",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
